<Window x:Class="QuickSpell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickSpell" Height="300" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Deactivated="Window_Deactivated">

    <Border Background="#2D2D30" CornerRadius="10" Padding="15" Margin="10" 
            BorderBrush="#3E3E42" BorderThickness="1">

        <StackPanel>
            <TextBox x:Name="SearchBox" Height="40" FontSize="20" Padding="5,4,5,0"
                     Background="#1E1E1E" Foreground="White" BorderThickness="0"
                     TextChanged="SearchBox_TextChanged" 
                     PreviewKeyDown="SearchBox_PreviewKeyDown"/>

            <ListBox x:Name="SuggestionList" Margin="0,10,0,0" Background="Transparent" 
                     BorderThickness="0" Foreground="#CCCCCC" FontSize="18"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </StackPanel>
    </Border>
</Window>